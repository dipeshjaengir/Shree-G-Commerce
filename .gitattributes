# Set default behavior to automatically handle line endings
* text=auto

# Force LF line endings for code files to prevent Windows CRLF conversions
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
